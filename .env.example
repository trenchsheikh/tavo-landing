# Supabase — copy this file to `.env.local` and fill in your project's values.
# Find them in your Supabase dashboard: Project Settings → API.
# These are the PUBLIC (anon) keys and are safe to expose in a frontend build;
# the database is protected by Row Level Security (see supabase/schema.sql).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
